---
import { getLangFromUrl } from '../i18n/translations';
const lang = getLangFromUrl(Astro.url);

const text = {
  ru: { msg: 'Мы используем файлы cookie для улучшения работы сайта.', accept: 'Принять', link: 'Подробнее' },
  et: { msg: 'Kasutame küpsiseid veebisaidi parandamiseks.', accept: 'Nõustun', link: 'Loe lähemalt' },
  fi: { msg: 'Käytämme evästeitä sivuston parantamiseen.', accept: 'Hyväksy', link: 'Lue lisää' },
}[lang];
---

<div id="cookie-banner"
	class="fixed bottom-0 left-0 right-0 z-50 bg-slate-900 border-t border-slate-700 px-4 py-3 hidden">
	<div class="max-w-6xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-3">
		<p class="text-slate-300 text-sm">
			{text.msg}
			<a href="/kupsised" class="text-blue-400 hover:text-blue-300 underline ml-1">{text.link}</a>
		</p>
		<button id="cookie-accept"
			class="flex-shrink-0 bg-blue-600 hover:bg-blue-500 text-white text-sm font-semibold px-5 py-2 rounded-lg transition-colors">
			{text.accept}
		</button>
	</div>
</div>

<script>
(function() {
	const banner = document.getElementById('cookie-banner');
	if (!banner) return;
	if (!localStorage.getItem('cookies-accepted')) {
		banner.classList.remove('hidden');
	}
	document.getElementById('cookie-accept')?.addEventListener('click', () => {
		localStorage.setItem('cookies-accepted', '1');
		banner.classList.add('hidden');
	});
})();
</script>
