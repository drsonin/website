---
import { CLINIC_PHONE } from '../consts';
import { getLangFromUrl, langLabels, getLocalizedPath, ui, type Lang } from '../i18n/translations';

const lang = getLangFromUrl(Astro.url);
const t = ui[lang].nav;
const langs: Lang[] = ['ru', 'et', 'fi'];
---

<header class="sticky top-0 z-50 bg-white border-b border-gray-100 shadow-sm">
	<nav class="max-w-6xl mx-auto px-4 sm:px-6 flex items-center justify-between h-16 gap-4">

		<!-- Logo -->
		<a href={getLocalizedPath(lang)} class="flex items-center gap-2 no-underline flex-shrink-0">
			<div class="w-8 h-8 bg-blue-600 rounded-lg flex items-center justify-center">
				<svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
					<path stroke-linecap="round" stroke-linejoin="round"
						d="M12 2C9 2 6.5 4 6.5 6.5c0 1.2.4 2.3.4 3.5 0 2-1 3.5-1 5.5 0 2 1 4 2.5 4s2-1.5 2.5-3.5c.3-1 .5-1.5 1.1-1.5s.8.5 1.1 1.5c.5 2 1 3.5 2.5 3.5s2.5-2 2.5-4c0-2-1-3.5-1-5.5 0-1.2.4-2.3.4-3.5C17.5 4 15 2 12 2z" />
				</svg>
			</div>
			<span class="text-slate-900 font-semibold text-base hidden sm:inline">
				<span class="font-bold">Sonin</span>
				<span class="text-slate-400 font-normal"> Hambaravi</span>
			</span>
		</a>

		<!-- Desktop nav -->
		<div class="hidden md:flex items-center gap-5 flex-1">
			<a href={getLocalizedPath(lang)} class="text-slate-600 hover:text-blue-600 font-medium text-sm transition-colors duration-150 no-underline">{t.home}</a>
			<a href="/about" class="text-slate-600 hover:text-blue-600 font-medium text-sm transition-colors duration-150 no-underline">{t.about}</a>
			<a href="/blog" class="text-slate-600 hover:text-blue-600 font-medium text-sm transition-colors duration-150 no-underline">{t.blog}</a>
		</div>

		<!-- Language switcher -->
		<div class="flex items-center gap-0.5 border border-slate-200 rounded-lg p-0.5 flex-shrink-0">
			{langs.map(l => (
				<a href={getLocalizedPath(l)}
					class:list={[
						'px-2.5 py-1 rounded text-xs font-bold transition-colors duration-150 no-underline',
						l === lang
							? 'bg-blue-600 text-white'
							: 'text-slate-400 hover:text-slate-700',
					]}>
					{langLabels[l]}
				</a>
			))}
		</div>

		<!-- CTA phone -->
		<a href={`tel:${CLINIC_PHONE}`}
			class="bg-blue-600 hover:bg-blue-700 text-white font-semibold px-4 py-2 rounded-lg text-sm transition-colors duration-150 no-underline flex-shrink-0 hidden sm:block">
			{CLINIC_PHONE}
		</a>
		<!-- Mobile: just phone icon -->
		<a href={`tel:${CLINIC_PHONE}`}
			class="sm:hidden w-9 h-9 bg-blue-600 hover:bg-blue-700 text-white rounded-lg flex items-center justify-center transition-colors duration-150 flex-shrink-0">
			<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
				<path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
			</svg>
		</a>

	</nav>
</header>
