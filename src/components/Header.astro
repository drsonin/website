---
import { CLINIC_PHONE } from '../consts';
import { getLangFromUrl, langLabels, getLocalizedPath, ui, type Lang } from '../i18n/translations';

const lang = getLangFromUrl(Astro.url);
const t = ui[lang].nav;
const langs: Lang[] = ['ru', 'et', 'fi'];
---

<header class="sticky top-0 z-50 bg-white border-b border-gray-100 shadow-sm">
	<nav class="max-w-6xl mx-auto px-4 sm:px-6 flex items-center justify-between h-16 gap-4">

		<!-- Logo -->
		<a href={getLocalizedPath(lang)} class="flex items-center gap-2 no-underline flex-shrink-0">
			<div class="w-8 h-8 bg-blue-600 rounded-lg flex items-center justify-center">
				<svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
					<path stroke-linecap="round" stroke-linejoin="round"
						d="M12 2C9 2 6.5 4 6.5 6.5c0 1.2.4 2.3.4 3.5 0 2-1 3.5-1 5.5 0 2 1 4 2.5 4s2-1.5 2.5-3.5c.3-1 .5-1.5 1.1-1.5s.8.5 1.1 1.5c.5 2 1 3.5 2.5 3.5s2.5-2 2.5-4c0-2-1-3.5-1-5.5 0-1.2.4-2.3.4-3.5C17.5 4 15 2 12 2z" />
				</svg>
			</div>
			<span class="text-slate-900 font-semibold text-base hidden sm:inline">
				<span class="font-bold">Sonin</span>
				<span class="text-slate-400 font-normal"> Hambaravi</span>
			</span>
		</a>

		<!-- Desktop nav -->
		<div class="hidden md:flex items-center gap-5 flex-1">
			<a href={getLocalizedPath(lang)} class="text-slate-600 hover:text-blue-600 font-medium text-sm transition-colors duration-150 no-underline">{t.home}</a>
			<a href="/about" class="text-slate-600 hover:text-blue-600 font-medium text-sm transition-colors duration-150 no-underline">{t.about}</a>
			<a href="/stories" class="text-slate-600 hover:text-blue-600 font-medium text-sm transition-colors duration-150 no-underline">{t.stories}</a>
			<a href="/blog" class="text-slate-600 hover:text-blue-600 font-medium text-sm transition-colors duration-150 no-underline">{t.blog}</a>
		</div>

		<!-- Language switcher -->
		<div class="flex items-center gap-0.5 border border-slate-200 rounded-lg p-0.5 flex-shrink-0">
			{langs.map(l => (
				<a href={getLocalizedPath(l)}
					class:list={[
						'px-2.5 py-1 rounded text-xs font-bold transition-colors duration-150 no-underline',
						l === lang
							? 'bg-blue-600 text-white'
							: 'text-slate-400 hover:text-slate-700',
					]}>
					{langLabels[l]}
				</a>
			))}
		</div>

		<!-- CTA phone (desktop) -->
		<a href={`tel:${CLINIC_PHONE}`}
			class="bg-blue-600 hover:bg-blue-700 text-white font-semibold px-4 py-2 rounded-lg text-sm transition-colors duration-150 no-underline flex-shrink-0 hidden md:block">
			{CLINIC_PHONE}
		</a>

		<!-- Mobile right: phone icon + hamburger -->
		<div class="flex items-center gap-2 md:hidden flex-shrink-0">
			<a href={`tel:${CLINIC_PHONE}`}
				class="w-9 h-9 bg-blue-600 hover:bg-blue-700 text-white rounded-lg flex items-center justify-center transition-colors duration-150 flex-shrink-0">
				<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
					<path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
				</svg>
			</a>
			<button id="burger-btn"
				class="w-9 h-9 flex items-center justify-center rounded-lg text-slate-600 hover:bg-slate-100 transition-colors duration-150"
				aria-label="Меню" aria-expanded="false" aria-controls="mobile-menu">
				<!-- Hamburger icon -->
				<svg id="burger-icon" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
					<path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
				</svg>
				<!-- Close icon (hidden by default) -->
				<svg id="close-icon" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
					<path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
				</svg>
			</button>
		</div>

	</nav>

	<!-- Mobile menu (hidden by default) -->
	<div id="mobile-menu"
		class="hidden md:hidden border-t border-slate-100 bg-white px-4 pb-4 pt-2">
		<div class="flex flex-col gap-1">
			<a href={getLocalizedPath(lang)}
				class="flex items-center gap-3 px-3 py-3 rounded-xl text-slate-700 hover:bg-slate-50 hover:text-blue-600 font-medium text-base transition-colors no-underline">
				<svg class="w-4 h-4 text-slate-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
					<path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
				</svg>
				{t.home}
			</a>
			<a href="/about"
				class="flex items-center gap-3 px-3 py-3 rounded-xl text-slate-700 hover:bg-slate-50 hover:text-blue-600 font-medium text-base transition-colors no-underline">
				<svg class="w-4 h-4 text-slate-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
					<path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
				</svg>
				{t.about}
			</a>
			<a href="/stories"
				class="flex items-center gap-3 px-3 py-3 rounded-xl text-slate-700 hover:bg-slate-50 hover:text-blue-600 font-medium text-base transition-colors no-underline">
				<svg class="w-4 h-4 text-slate-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
					<path stroke-linecap="round" stroke-linejoin="round" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/>
				</svg>
				{t.stories}
			</a>
			<a href="/blog"
				class="flex items-center gap-3 px-3 py-3 rounded-xl text-slate-700 hover:bg-slate-50 hover:text-blue-600 font-medium text-base transition-colors no-underline">
				<svg class="w-4 h-4 text-slate-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
					<path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/>
				</svg>
				{t.blog}
			</a>
			<!-- Phone CTA in menu -->
			<div class="mt-2 pt-2 border-t border-slate-100">
				<a href={`tel:${CLINIC_PHONE}`}
					class="flex items-center justify-center gap-2 bg-blue-600 hover:bg-blue-700 text-white font-bold px-4 py-3 rounded-xl text-sm transition-colors no-underline">
					<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
						<path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
					</svg>
					{CLINIC_PHONE}
				</a>
			</div>
		</div>
	</div>
</header>

<script>
	const btn = document.getElementById('burger-btn')!;
	const menu = document.getElementById('mobile-menu')!;
	const burgerIcon = document.getElementById('burger-icon')!;
	const closeIcon = document.getElementById('close-icon')!;

	btn.addEventListener('click', () => {
		const isOpen = !menu.classList.contains('hidden');
		menu.classList.toggle('hidden', isOpen);
		burgerIcon.classList.toggle('hidden', !isOpen);
		closeIcon.classList.toggle('hidden', isOpen);
		btn.setAttribute('aria-expanded', String(!isOpen));
	});

	// Close menu when a link is clicked
	menu.querySelectorAll('a').forEach(link => {
		link.addEventListener('click', () => {
			menu.classList.add('hidden');
			burgerIcon.classList.remove('hidden');
			closeIcon.classList.add('hidden');
			btn.setAttribute('aria-expanded', 'false');
		});
	});
</script>
