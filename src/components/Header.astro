---
import { CLINIC_PHONE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<a href="/" class="logo">
			<strong>Sonin</strong> Hambaravi
		</a>
		<div class="internal-links">
			<HeaderLink href="/">Главная</HeaderLink>
			<HeaderLink href="/blog">Блог</HeaderLink>
			<HeaderLink href="/about">О враче</HeaderLink>
		</div>
		<div class="cta">
			<a href={`tel:${CLINIC_PHONE}`} class="phone">{CLINIC_PHONE}</a>
		</div>
	</nav>
</header>

<style>
	header {
		margin: 0;
		padding: 0 1.5em;
		background: white;
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
		position: sticky;
		top: 0;
		z-index: 100;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 960px;
		margin: 0 auto;
		height: 60px;
	}
	.logo {
		text-decoration: none;
		color: rgb(var(--black));
		font-size: 1.1em;
	}
	nav a {
		padding: 0.5em;
		color: rgb(var(--black));
		border-bottom: 3px solid transparent;
		text-decoration: none;
	}
	nav a.active {
		border-bottom-color: var(--accent);
	}
	.phone {
		background: var(--accent);
		color: white !important;
		padding: 0.5em 1em !important;
		border-radius: 6px;
		border-bottom: none !important;
		font-weight: bold;
	}
	.phone:hover {
		opacity: 0.9;
	}
	@media (max-width: 720px) {
		.internal-links { display: none; }
		.phone { font-size: 0.85em; }
	}
</style>
