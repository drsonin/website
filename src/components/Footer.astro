---
import { CLINIC_ADDRESS, CLINIC_EMAIL, CLINIC_PHONE } from '../consts';
const today = new Date();
---

<footer>
	<div class="footer-grid">
		<div>
			<strong>Sonin Hambaravi</strong>
			<p>{CLINIC_ADDRESS}</p>
			<p>Пн–Сб: 10:00–17:00</p>
		</div>
		<div>
			<strong>Контакты</strong>
			<p><a href={`tel:${CLINIC_PHONE}`}>{CLINIC_PHONE}</a></p>
			<p><a href={`mailto:${CLINIC_EMAIL}`}>{CLINIC_EMAIL}</a></p>
		</div>
		<div>
			<strong>Мы в соцсетях</strong>
			<p><a href="https://www.instagram.com/sonin.dentaltour" target="_blank">Instagram клиники</a></p>
			<p><a href="https://www.instagram.com/dr.dmitri_sonin" target="_blank">Instagram доктора</a></p>
			<p><a href="https://www.youtube.com/@sonindmitri" target="_blank">YouTube</a></p>
		</div>
	</div>
	<div class="copy">
		&copy; {today.getFullYear()} Sonin Hambaravi OÜ. Все права защищены.
	</div>
</footer>

<style>
	footer {
		padding: 3em 1.5em 2em;
		background: rgb(var(--gray-dark));
		color: rgba(255,255,255,0.7);
		margin-top: 4em;
	}
	.footer-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 2em;
		max-width: 960px;
		margin: 0 auto 2em;
	}
	strong { color: white; display: block; margin-bottom: 0.5em; }
	p { margin: 0.3em 0; font-size: 0.9em; }
	a { color: rgba(255,255,255,0.7); text-decoration: none; }
	a:hover { color: white; }
	.copy {
		text-align: center;
		font-size: 0.8em;
		border-top: 1px solid rgba(255,255,255,0.1);
		padding-top: 1.5em;
		max-width: 960px;
		margin: 0 auto;
	}
	@media (max-width: 720px) {
		.footer-grid { grid-template-columns: 1fr; gap: 1.5em; }
	}
</style>
