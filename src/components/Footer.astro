---
import { CLINIC_ADDRESS, CLINIC_EMAIL, CLINIC_PHONE } from '../consts';
import { getLangFromUrl, ui } from '../i18n/translations';

const lang = getLangFromUrl(Astro.url);
const t = ui[lang].footer;
const year = new Date().getFullYear();
---

<footer class="bg-slate-900 text-slate-400 pt-16 pb-8">
	<div class="max-w-6xl mx-auto px-4 sm:px-6">

		<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10 mb-12">

			<!-- Brand -->
			<div class="lg:col-span-2">
				<div class="flex items-center gap-2 mb-4">
					<div class="w-8 h-8 bg-blue-600 rounded-lg flex items-center justify-center">
						<svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
							<path stroke-linecap="round" stroke-linejoin="round"
								d="M12 2C9 2 6.5 4 6.5 6.5c0 1.2.4 2.3.4 3.5 0 2-1 3.5-1 5.5 0 2 1 4 2.5 4s2-1.5 2.5-3.5c.3-1 .5-1.5 1.1-1.5s.8.5 1.1 1.5c.5 2 1 3.5 2.5 3.5s2.5-2 2.5-4c0-2-1-3.5-1-5.5 0-1.2.4-2.3.4-3.5C17.5 4 15 2 12 2z" />
						</svg>
					</div>
					<span class="text-white font-bold text-base">Sonin Hambaravi</span>
				</div>
				<p class="text-sm leading-relaxed max-w-xs mb-4">{t.desc}</p>
				<p class="text-sm">{CLINIC_ADDRESS}</p>
				<p class="text-sm mt-1">{t.hours}</p>
			</div>

			<!-- Contacts -->
			<div>
				<p class="text-white font-semibold text-sm mb-4">{t.contactTitle}</p>
				<ul class="space-y-2 text-sm">
					<li>
						<a href={`tel:${CLINIC_PHONE}`} class="text-slate-400 hover:text-white transition-colors duration-150 no-underline">
							{CLINIC_PHONE}
						</a>
					</li>
					<li>
						<a href={`mailto:${CLINIC_EMAIL}`} class="text-slate-400 hover:text-white transition-colors duration-150 no-underline">
							{CLINIC_EMAIL}
						</a>
					</li>
				</ul>
			</div>

			<!-- Social -->
			<div>
				<p class="text-white font-semibold text-sm mb-4">{t.socialTitle}</p>
				<ul class="space-y-2 text-sm">
					<li>
						<a href="https://www.instagram.com/sonin.dentaltour" target="_blank" rel="noopener"
							class="text-slate-400 hover:text-white transition-colors duration-150 no-underline">
							{t.ig1}
						</a>
					</li>
					<li>
						<a href="https://www.instagram.com/dr.dmitri_sonin" target="_blank" rel="noopener"
							class="text-slate-400 hover:text-white transition-colors duration-150 no-underline">
							{t.ig2}
						</a>
					</li>
					<li>
						<a href="https://www.youtube.com/@sonindmitri" target="_blank" rel="noopener"
							class="text-slate-400 hover:text-white transition-colors duration-150 no-underline">
							{t.yt}
						</a>
					</li>
				</ul>
			</div>

		</div>

		<div class="border-t border-slate-800 pt-6 flex flex-col sm:flex-row justify-between items-center gap-2 text-xs text-slate-500">
			<p>&copy; {year} Sonin Hambaravi OÜ. {t.copyright}</p>
			<p>{t.location}</p>
		</div>

	</div>
</footer>
