---
import { Image } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { CLINIC_ADDRESS, CLINIC_EMAIL, CLINIC_PHONE } from '../consts';
import { getLangFromUrl, ui } from '../i18n/translations';
import doctorPhoto from '../assets/images/doctor-sonin.png';
import CookieBanner from '../components/CookieBanner.astro';

const lang = getLangFromUrl(Astro.url);
const t = ui[lang];
---

<!doctype html>
<html lang={lang}>
<head>
	<BaseHead title={t.meta.title} description={t.meta.description} />
</head>
<body class="bg-white text-slate-800 antialiased">
<Header />
<main>

	<!-- ═══ HERO ════════════════════════════════════════════ -->
	<section class="relative bg-gradient-to-br from-slate-900 via-blue-950 to-slate-900 text-white overflow-hidden">
		<div class="absolute top-0 right-0 w-96 h-96 bg-blue-700/10 rounded-full -translate-y-1/3 translate-x-1/3 pointer-events-none"></div>
		<div class="absolute bottom-0 left-0 w-64 h-64 bg-blue-500/10 rounded-full translate-y-1/3 -translate-x-1/4 pointer-events-none"></div>

		<div class="relative max-w-6xl mx-auto px-4 sm:px-6 py-24 md:py-36 text-center">
			<span class="inline-flex items-center gap-2 bg-blue-900/60 border border-blue-700/50 text-blue-300 text-xs font-semibold uppercase tracking-widest px-4 py-1.5 rounded-full mb-8">
				<span class="w-1.5 h-1.5 bg-blue-400 rounded-full inline-block"></span>
				{t.hero.badge}
			</span>

			<h1 class="text-4xl sm:text-5xl md:text-6xl font-bold leading-tight mb-6">
				{t.hero.title}<br/>
				<span class="text-blue-400">{t.hero.titleAccent}</span>
			</h1>

			<p class="text-lg md:text-xl text-slate-300 max-w-2xl mx-auto mb-10 leading-relaxed whitespace-pre-line">
				{t.hero.subtitle}
			</p>

			<div class="flex flex-col sm:flex-row gap-4 justify-center mb-16">
				<a href="#contact"
					class="inline-flex items-center justify-center gap-2 bg-blue-600 hover:bg-blue-500 text-white font-bold px-8 py-4 rounded-xl text-base transition-colors duration-200 no-underline shadow-lg shadow-blue-900/40">
					{t.hero.ctaForm}
				</a>
				<a href={`tel:${CLINIC_PHONE}`}
					class="inline-flex items-center justify-center gap-2 border-2 border-white/20 hover:border-white/50 text-white font-semibold px-8 py-4 rounded-xl text-base transition-colors duration-200 no-underline">
					<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
						<path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
					</svg>
					{t.hero.ctaCall} {CLINIC_PHONE}
				</a>
			</div>

			<div class="grid grid-cols-2 sm:grid-cols-4 gap-6 max-w-3xl mx-auto border-t border-white/10 pt-10">
				{[
					{ n: t.hero.s1n, l: t.hero.s1l },
					{ n: t.hero.s2n, l: t.hero.s2l },
					{ n: t.hero.s3n, l: t.hero.s3l },
					{ n: t.hero.s4n, l: t.hero.s4l },
				].map(s => (
					<div class="text-center">
						<div class="text-2xl sm:text-3xl font-bold text-white mb-1">{s.n}</div>
						<div class="text-xs text-slate-400 leading-tight">{s.l}</div>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- ═══ ПРЕИМУЩЕСТВА ════════════════════════════════════ -->
	<section class="py-20 bg-white px-4 sm:px-6">
		<div class="max-w-6xl mx-auto">
			<div class="text-center mb-14">
				<p class="text-blue-600 text-sm font-semibold uppercase tracking-widest mb-3">{t.features.sup}</p>
				<h2 class="text-3xl sm:text-4xl font-bold text-slate-900">{t.features.title}</h2>
			</div>

			<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
				{[
					{
						icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z',
						title: t.features.f1t, desc: t.features.f1d,
					},
					{
						icon: 'M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z',
						title: t.features.f2t, desc: t.features.f2d,
					},
					{
						icon: 'M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z',
						title: t.features.f3t, desc: t.features.f3d,
					},
					{
						icon: 'M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129',
						title: t.features.f4t, desc: t.features.f4d,
					},
				].map(f => (
					<div class="group flex flex-col items-start p-6 rounded-2xl border border-slate-100 hover:border-blue-100 hover:bg-blue-50/40 transition-all duration-200">
						<div class="w-12 h-12 bg-blue-100 rounded-xl flex items-center justify-center mb-5 group-hover:bg-blue-600 transition-colors duration-200">
							<svg class="w-6 h-6 text-blue-600 group-hover:text-white transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
								<path stroke-linecap="round" stroke-linejoin="round" d={f.icon}/>
							</svg>
						</div>
						<h3 class="font-bold text-slate-900 text-base mb-2">{f.title}</h3>
						<p class="text-slate-500 text-sm leading-relaxed">{f.desc}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- ═══ УСЛУГИ ══════════════════════════════════════════ -->
	<section class="py-20 bg-slate-50 px-4 sm:px-6">
		<div class="max-w-6xl mx-auto">
			<div class="text-center mb-14">
				<p class="text-blue-600 text-sm font-semibold uppercase tracking-widest mb-3">{t.services.sup}</p>
				<h2 class="text-3xl sm:text-4xl font-bold text-slate-900">{t.services.title}</h2>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
				{[
					{
						icon: 'M12 2C9 2 6.5 4 6.5 6.5c0 1.2.4 2.3.4 3.5 0 2-1 3.5-1 5.5 0 2 1 4 2.5 4s2-1.5 2.5-3.5c.3-1 .5-1.5 1.1-1.5s.8.5 1.1 1.5c.5 2 1 3.5 2.5 3.5s2.5-2 2.5-4c0-2-1-3.5-1-5.5 0-1.2.4-2.3.4-3.5C17.5 4 15 2 12 2z',
						title: t.services.s1t, desc: t.services.s1d,
						b: [t.services.s1b1, t.services.s1b2, t.services.s1b3],
					},
					{
						icon: 'M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v10m0 0h10M9 13H5a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2h-4',
						title: t.services.s2t, desc: t.services.s2d,
						b: [t.services.s2b1, t.services.s2b2, t.services.s2b3],
					},
					{
						icon: 'M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z',
						title: t.services.s3t, desc: t.services.s3d,
						b: [t.services.s3b1, t.services.s3b2, t.services.s3b3],
					},
				].map(s => (
					<div class="bg-white rounded-2xl p-8 shadow-sm border border-slate-100 hover:shadow-md hover:-translate-y-1 transition-all duration-200 flex flex-col">
						<div class="w-14 h-14 bg-blue-600 rounded-2xl flex items-center justify-center mb-6">
							<svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
								<path stroke-linecap="round" stroke-linejoin="round" d={s.icon}/>
							</svg>
						</div>
						<h3 class="text-xl font-bold text-slate-900 mb-3">{s.title}</h3>
						<p class="text-slate-500 text-sm leading-relaxed mb-6 flex-grow">{s.desc}</p>
						<ul class="text-xs text-slate-400 space-y-1.5 mb-6">
							{s.b.map(item => (
								<li class="flex items-center gap-2">
									<span class="w-1 h-1 bg-blue-400 rounded-full flex-shrink-0"></span>
									{item}
								</li>
							))}
						</ul>
						<a href={`tel:${CLINIC_PHONE}`} class="text-blue-600 hover:text-blue-700 font-semibold text-sm inline-flex items-center gap-1 no-underline">
							{t.services.cta}
							<svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
								<path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
							</svg>
						</a>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- ═══ О ДОКТОРЕ ═══════════════════════════════════════ -->
	<section class="py-20 bg-white px-4 sm:px-6">
		<div class="max-w-6xl mx-auto">
			<div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
				<div>
					<p class="text-blue-600 text-sm font-semibold uppercase tracking-widest mb-3">{t.about.sup}</p>
					<h2 class="text-3xl sm:text-4xl font-bold text-slate-900 mb-6">{t.about.name}</h2>
					<p class="text-slate-600 leading-relaxed mb-8">{t.about.desc}</p>

					<div class="space-y-5 mb-10">
						{[
							{ icon: 'M12 14l9-5-9-5-9 5 9 5z M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z', title: t.about.e1t, sub: t.about.e1s },
							{ icon: 'M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z', title: t.about.e2t, sub: t.about.e2s },
							{ icon: 'M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129', title: t.about.e3t, sub: t.about.e3s },
						].map(e => (
							<div class="flex gap-4">
								<div class="flex-shrink-0 w-10 h-10 bg-blue-50 rounded-xl flex items-center justify-center mt-0.5">
									<svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
										<path stroke-linecap="round" stroke-linejoin="round" d={e.icon}/>
									</svg>
								</div>
								<div>
									<p class="font-semibold text-slate-800 text-sm">{e.title}</p>
									<p class="text-slate-500 text-sm">{e.sub}</p>
								</div>
							</div>
						))}
					</div>

					<a href="/about"
						class="inline-flex items-center gap-2 bg-slate-900 hover:bg-blue-700 text-white font-semibold px-6 py-3 rounded-xl text-sm transition-colors duration-200 no-underline">
						{t.about.btn}
						<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
							<path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
						</svg>
					</a>
				</div>

				<div class="relative">
					<div class="rounded-3xl overflow-hidden relative">
						<Image
							src={doctorPhoto}
							alt={t.about.name}
							width={600}
							height={750}
							class="w-full h-full object-cover object-top"
							loading="eager"
						/>
						<div class="absolute bottom-0 left-0 right-0 h-1/4 bg-gradient-to-t from-slate-900/20 to-transparent"></div>
					</div>
					<div class="absolute -bottom-4 -right-4 bg-white rounded-2xl shadow-lg px-5 py-4 flex items-center gap-3 border border-slate-100">
						<div class="w-10 h-10 bg-blue-600 rounded-xl flex items-center justify-center flex-shrink-0">
							<svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
								<path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
							</svg>
						</div>
						<div>
							<p class="text-slate-900 font-bold text-sm">{t.about.badgeLabel}</p>
							<p class="text-slate-400 text-xs">{t.about.badgeSub}</p>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- ═══ ОТЗЫВЫ ══════════════════════════════════════════ -->
	<section class="py-20 bg-slate-900 px-4 sm:px-6">
		<div class="max-w-6xl mx-auto">
			<div class="text-center mb-14">
				<p class="text-blue-400 text-sm font-semibold uppercase tracking-widest mb-3">{t.reviews.sup}</p>
				<h2 class="text-3xl sm:text-4xl font-bold text-white">{t.reviews.title}</h2>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
				{[
					{ name: t.reviews.r1n, city: t.reviews.r1c, text: t.reviews.r1t },
					{ name: t.reviews.r2n, city: t.reviews.r2c, text: t.reviews.r2t },
					{ name: t.reviews.r3n, city: t.reviews.r3c, text: t.reviews.r3t },
				].map(r => (
					<div class="bg-slate-800/60 border border-slate-700/50 rounded-2xl p-7 flex flex-col">
						<div class="flex gap-1 mb-4">
							{[1,2,3,4,5].map(() => (
								<svg class="w-4 h-4 text-yellow-400 fill-current" viewBox="0 0 20 20">
									<path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
								</svg>
							))}
						</div>
						<p class="text-slate-300 text-sm leading-relaxed flex-grow mb-6">"{r.text}"</p>
						<div>
							<p class="text-white font-semibold text-sm">{r.name}</p>
							<p class="text-slate-500 text-xs">{r.city}</p>
						</div>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- ═══ ПАРТНЁРЫ ═══════════════════════════════════════ -->
	<section class="py-8 bg-slate-50 border-y border-slate-100 px-4 sm:px-6">
		<div class="max-w-6xl mx-auto">
			<div class="flex flex-col sm:flex-row items-center justify-between gap-6">

				<!-- Ассоциации -->
				<div class="flex flex-col items-center sm:items-start gap-2">
					<p class="text-slate-400 text-xs uppercase tracking-widest font-semibold">Professionaalsed ühendused</p>
					<div class="flex items-center gap-3 flex-wrap justify-center sm:justify-start">
						{['EHL', 'EIO', 'DGI'].map(name => (
							<span class="inline-flex items-center border border-slate-300 text-slate-600 text-xs font-bold px-3 py-1.5 rounded-lg bg-white tracking-wide">
								{name}
							</span>
						))}
					</div>
				</div>

				<!-- Разделитель -->
				<div class="hidden sm:block w-px h-10 bg-slate-200"></div>

				<!-- Оборудование -->
				<div class="flex flex-col items-center sm:items-end gap-2">
					<p class="text-slate-400 text-xs uppercase tracking-widest font-semibold">Sertifitseeritud seadmed</p>
					<div class="flex items-center gap-3 flex-wrap justify-center sm:justify-end">
						{['Nobel Biocare', 'Osstem', 'Medit', 'Planmeca'].map(name => (
							<span class="inline-flex items-center border border-slate-300 text-slate-600 text-xs font-semibold px-3 py-1.5 rounded-lg bg-white">
								{name}
							</span>
						))}
					</div>
				</div>

			</div>
		</div>
	</section>

	<!-- ═══ ФОРМА ЗАПИСИ ════════════════════════════════════ -->
	<section id="contact" class="py-20 bg-white px-4 sm:px-6">
		<div class="max-w-6xl mx-auto">
			<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">

				<div>
					<p class="text-blue-600 text-sm font-semibold uppercase tracking-widest mb-3">{t.contact.sup}</p>
					<h2 class="text-3xl sm:text-4xl font-bold text-slate-900 mb-6">{t.contact.title}</h2>
					<p class="text-slate-500 leading-relaxed mb-8">{t.contact.desc}</p>

					<!-- Контакты -->
					<div class="space-y-5 mb-8">
						<div class="flex items-center gap-4">
							<div class="w-10 h-10 bg-blue-600 rounded-xl flex items-center justify-center flex-shrink-0">
								<svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
									<path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
								</svg>
							</div>
							<div>
								<p class="text-slate-400 text-xs uppercase tracking-wide mb-0.5">{t.contact.lPhone}</p>
								<a href={`tel:${CLINIC_PHONE}`} class="text-slate-900 font-bold text-xl no-underline hover:text-blue-600 transition-colors">{CLINIC_PHONE}</a>
							</div>
						</div>
						<div class="flex items-center gap-4">
							<div class="w-10 h-10 bg-blue-50 rounded-xl flex items-center justify-center flex-shrink-0">
								<svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
									<path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
								</svg>
							</div>
							<div>
								<p class="text-slate-400 text-xs uppercase tracking-wide mb-0.5">{t.contact.lEmail}</p>
								<a href={`mailto:${CLINIC_EMAIL}`} class="text-slate-900 font-semibold no-underline hover:text-blue-600 transition-colors">{CLINIC_EMAIL}</a>
							</div>
						</div>
						<div class="flex items-center gap-4">
							<div class="w-10 h-10 bg-blue-50 rounded-xl flex items-center justify-center flex-shrink-0">
								<svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
									<path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
								</svg>
							</div>
							<div>
								<p class="text-slate-400 text-xs uppercase tracking-wide mb-0.5">{t.contact.hours}</p>
								<p class="text-slate-900 font-semibold">{{ru:'Пн–Сб: 10:00–17:00', et:'E–L: 10:00–17:00', fi:'Ma–La: 10:00–17:00', en:'Mon–Sat: 10:00–17:00'}[lang]}</p>
							</div>
						</div>
					</div>

					<!-- Доверие-бейджи -->
					<div class="grid grid-cols-2 gap-3">
						{[
