---
import { Image } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { CLINIC_PHONE } from '../consts';
import CookieBanner from '../components/CookieBanner.astro';
import doctorPhoto from '../assets/images/doctor-sonin.png';
import { getLangFromUrl, aboutT } from '../i18n/translations';

const lang = getLangFromUrl(Astro.url);
const t = aboutT[lang];
---

<!doctype html>
<html lang={lang}>
<head>
	<BaseHead title={t.meta.title} description={t.meta.description} />
</head>
<body class="bg-white text-slate-800 antialiased">
<Header />
<main>

	<!-- ═══ HERO ════════════════════════════════════════════ -->
	<section class="bg-gradient-to-br from-slate-900 via-blue-950 to-slate-900 text-white py-20 px-4 sm:px-6">
		<div class="max-w-6xl mx-auto">
			<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

				<div>
					<span class="inline-flex items-center gap-2 bg-blue-900/60 border border-blue-700/50 text-blue-300 text-xs font-semibold uppercase tracking-widest px-4 py-1.5 rounded-full mb-6">
						<span class="w-1.5 h-1.5 bg-blue-400 rounded-full"></span>
						{t.badge}
					</span>
					<h1 class="text-4xl sm:text-5xl font-bold leading-tight mb-4">{t.name}</h1>
					<p class="text-xl text-blue-300 font-medium mb-6">Master of Oral Implantology</p>
					<p class="text-slate-300 leading-relaxed mb-8 max-w-lg">{t.subtitle}</p>
					<div class="flex flex-col sm:flex-row gap-4">
						<a href={lang === 'ru' ? '/#contact' : `/${lang}/#contact`}
							class="inline-flex items-center justify-center gap-2 bg-blue-600 hover:bg-blue-500 text-white font-bold px-6 py-3.5 rounded-xl text-sm transition-colors no-underline">
							{t.ctaForm}
						</a>
						<a href={`tel:${CLINIC_PHONE}`}
							class="inline-flex items-center justify-center gap-2 border-2 border-white/30 hover:border-white/60 text-white font-semibold px-6 py-3.5 rounded-xl text-sm transition-colors no-underline">
							<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
								<path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
							</svg>
							{t.ctaCall}
						</a>
					</div>
				</div>

				<div class="flex justify-center lg:justify-end">
					<div class="relative w-72 sm:w-80">
						<div class="rounded-3xl overflow-hidden shadow-2xl shadow-blue-900/40">
							<Image src={doctorPhoto} alt={t.name} width={400} height={500}
								class="w-full object-cover object-top" loading="eager" />
						</div>
						<div class="absolute -bottom-4 -left-4 bg-white rounded-2xl shadow-lg px-4 py-3 flex items-center gap-3 border border-slate-100">
							<div class="w-9 h-9 bg-blue-600 rounded-xl flex items-center justify-center flex-shrink-0">
								<svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
									<path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
								</svg>
							</div>
							<div>
								<p class="text-slate-900 font-bold text-sm leading-tight">{t.badgeYears}</p>
								<p class="text-slate-400 text-xs">{t.badgeSub}</p>
							</div>
						</div>
					</div>
				</div>

			</div>
		</div>
	</section>

	<!-- ═══ СТАТИСТИКА ══════════════════════════════════════ -->
	<section class="py-12 bg-white border-b border-slate-100 px-4 sm:px-6">
		<div class="max-w-6xl mx-auto">
			<div class="grid grid-cols-2 sm:grid-cols-4 gap-8 text-center">
				{[
					{ num: '19', label: t.stats[0] },
					{ num: '2005', label: t.stats[1] },
					{ num: '4', label: t.stats[2] },
					{ num: 'Master', label: t.stats[3] },
				].map(s => (
					<div>
						<div class="text-3xl font-bold text-blue-600 mb-1">{s.num}</div>
						<div class="text-sm text-slate-500">{s.label}</div>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- ═══ БИОГРАФИЯ ═══════════════════════════════════════ -->
	<section class="py-20 bg-white px-4 sm:px-6">
		<div class="max-w-4xl mx-auto">
			<p class="text-blue-600 text-sm font-semibold uppercase tracking-widest mb-3">{t.bioSup}</p>
			<h2 class="text-3xl font-bold text-slate-900 mb-8">{t.bioTitle}</h2>
			<div class="space-y-5 text-slate-600 leading-relaxed">
				<p>{t.bio1}</p>
				<p>{t.bio2}</p>
				<p>{t.bio3}</p>
			</div>
		</div>
	</section>

	<!-- ═══ ОБРАЗОВАНИЕ ══════════════════════════════════════ -->
	<section class="py-20 bg-slate-50 px-4 sm:px-6">
		<div class="max-w-4xl mx-auto">
			<p class="text-blue-600 text-sm font-semibold uppercase tracking-widest mb-3">{t.eduSup}</p>
			<h2 class="text-3xl font-bold text-slate-900 mb-12">{t.eduTitle}</h2>
			<div class="relative">
				<div class="absolute left-5 top-0 bottom-0 w-px bg-slate-200 hidden sm:block"></div>
				<div class="space-y-10">
					{t.edu.map(e => (
						<div class="flex gap-6 items-start">
							<div class:list={['flex-shrink-0 w-10 h-10 rounded-xl flex items-center justify-center z-10', e.accent ? 'bg-blue-600' : 'bg-slate-200']}>
								<svg class:list={['w-5 h-5', e.accent ? 'text-white' : 'text-slate-500']}
									fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
									<path stroke-linecap="round" stroke-linejoin="round" d="M12 14l9-5-9-5-9 5 9 5z M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"/>
								</svg>
							</div>
							<div class="flex-1 pb-2">
								<span class="text-xs font-semibold text-blue-600 uppercase tracking-wide">{e.year}</span>
								<h3 class="text-lg font-bold text-slate-900 mt-0.5 mb-1">{e.title}</h3>
								<p class="text-sm font-medium text-slate-500 mb-2">{e.place}</p>
								<p class="text-sm text-slate-500 leading-relaxed">{e.desc}</p>
							</div>
						</div>
					))}
				</div>
			</div>
		</div>
	</section>

	<!-- ═══ СПЕЦИАЛИЗАЦИИ ═══════════════════════════════════ -->
	<section class="py-20 bg-white px-4 sm:px-6">
		<div class="max-w-4xl mx-auto">
			<p class="text-blue-600 text-sm font-semibold uppercase tracking-widest mb-3">{t.specSup}</p>
			<h2 class="text-3xl font-bold text-slate-900 mb-10">{t.specTitle}</h2>
			<div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
				{t.specs.map(s => (
					<div class="bg-slate-50 rounded-2xl p-6 border border-slate-100">
						<h3 class="font-bold text-slate-900 text-base mb-4">{s.title}</h3>
						<ul class="space-y-2">
							{s.items.map(item => (
								<li class="flex items-center gap-2 text-sm text-slate-600">
									<span class="w-1.5 h-1.5 bg-blue-500 rounded-full flex-shrink-0"></span>
									{item}
								</li>
							))}
						</ul>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- ═══ ЯЗЫКИ ════════════════════════════════════════════ -->
	<section class="py-16 bg-blue-600 px-4 sm:px-6">
		<div class="max-w-4xl mx-auto text-center">
			<h2 class="text-2xl font-bold text-white mb-3">{t.langTitle}</h2>
			<p class="text-blue-100 mb-8">{t.langSub}</p>
			<div class="flex flex-wrap justify-center gap-4">
				{[
					{ flag: '🇪🇪', lang: 'Eesti keel', sub: lang === 'ru' ? 'Эстонский' : lang === 'et' ? 'Eesti' : lang === 'fi' ? 'Viro' : 'Estonian' },
					{ flag: '🇫🇮', lang: 'Suomi', sub: lang === 'ru' ? 'Финский' : lang === 'et' ? 'Soome' : lang === 'fi' ? 'Suomi' : 'Finnish' },
					{ flag: '🇬🇧', lang: 'English', sub: lang === 'ru' ? 'Английский' : lang === 'et' ? 'Inglise' : lang === 'fi' ? 'Englanti' : 'English' },
					{ flag: '🇩🇪', lang: 'Deutsch', sub: lang === 'ru' ? 'Немецкий' : lang === 'et' ? 'Saksa' : lang === 'fi' ? 'Saksa' : 'German' },
				].map(l => (
					<div class="bg-white/10 border border-white/20 rounded-2xl px-6 py-4 text-center min-w-[120px]">
						<div class="text-3xl mb-1">{l.flag}</div>
						<div class="text-white font-semibold text-sm">{l.lang}</div>
						<div class="text-blue-200 text-xs">{l.sub}</div>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- ═══ CTA ══════════════════════════════════════════════ -->
	<section class="py-20 bg-white px-4 sm:px-6">
		<div class="max-w-2xl mx-auto text-center">
			<h2 class="text-3xl font-bold text-slate-900 mb-4">{t.ctaTitle}</h2>
			<p class="text-slate-500 mb-8">{t.ctaDesc}</p>
			<div class="flex flex-col sm:flex-row gap-4 justify-center">
				<a href={lang === 'ru' ? '/#contact' : `/${lang}/#contact`}
					class="inline-flex items-center justify-center gap-2 bg-blue-600 hover:bg-blue-700 text-white font-bold px-8 py-4 rounded-xl text-base transition-colors no-underline shadow-lg shadow-blue-100">
					{t.ctaBtn}
				</a>
				<a href={`tel:${CLINIC_PHONE}`}
					class="inline-flex items-center justify-center gap-2 border-2 border-blue-200 hover:border-blue-400 text-blue-700 font-semibold px-8 py-4 rounded-xl text-base transition-colors no-underline">
					<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
						<path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
					</svg>
					{CLINIC_PHONE}
				</a>
			</div>
		</div>
	</section>

</main>
<Footer />
<CookieBanner />
</body>
</html>
