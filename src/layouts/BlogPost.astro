---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, author, lang } = Astro.props;

const langMeta: Record<string, { label: string; flag: string }> = {
	ru: { label: 'Русский', flag: '🇷🇺' },
	et: { label: 'Eesti',   flag: '🇪🇪' },
	fi: { label: 'Suomi',   flag: '🇫🇮' },
};
const lm = langMeta[lang ?? 'ru'] ?? langMeta.ru;

const blogLang = (lang ?? 'ru') as 'ru' | 'et' | 'fi';
const t = {
	ru: { home: 'Главная',  blog: 'Блог',  allPosts: 'Все статьи',      bookBtn: 'Записаться на приём', updated: 'Обновлено:' },
	et: { home: 'Avaleht',  blog: 'Blogi', allPosts: 'Kõik artiklid',   bookBtn: 'Registreeri visiidile', updated: 'Uuendatud:' },
	fi: { home: 'Etusivu',  blog: 'Blogi', allPosts: 'Kaikki artikkelit', bookBtn: 'Varaa aika',          updated: 'Päivitetty:' },
}[blogLang];
const homeHref = blogLang === 'ru' ? '/' : `/${blogLang}/`;
---

<html lang={lang ?? 'ru'}>
<head>
	<BaseHead title={`${title} — Sonin Hambaravi`} description={description} />
</head>

<body class="bg-white text-slate-800 antialiased">
<Header />
<main>

	<!-- ═══ HERO ИЗОБРАЖЕНИЕ ════════════════════════════════ -->
	{heroImage && (
		<div class="w-full max-h-[420px] overflow-hidden">
			<img
				src={heroImage}
				alt={title}
				width={1200}
				height={500}
				class="w-full object-cover max-h-[420px]"
				loading="eager"
			/>
		</div>
	)}

	<!-- ═══ КОНТЕНТ ══════════════════════════════════════════ -->
	<article class="max-w-2xl mx-auto px-4 sm:px-6 py-14">

		<!-- Хлебные крошки -->
		<nav class="flex items-center gap-2 text-xs text-slate-400 mb-8">
			<a href={homeHref} class="hover:text-blue-600 transition-colors no-underline">{t.home}</a>
			<svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
				<path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
			</svg>
			<a href="/blog" class="hover:text-blue-600 transition-colors no-underline">{t.blog}</a>
			<svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
				<path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
			</svg>
			<span class="text-slate-500 truncate max-w-[180px]">{title}</span>
		</nav>

		<!-- Мета -->
		<div class="flex flex-wrap items-center gap-3 mb-6">
			<span class="bg-blue-100 text-blue-700 text-xs font-bold px-2.5 py-1 rounded-md">
				{lm.flag} {lm.label}
			</span>
			<span class="text-slate-400 text-sm">
				<FormattedDate date={pubDate} />
			</span>
			{author && (
				<span class="text-slate-400 text-sm">— {author}</span>
			)}
			{updatedDate && (
				<span class="text-slate-400 text-xs italic">
					{t.updated} <FormattedDate date={updatedDate} />
				</span>
			)}
		</div>

		<!-- Заголовок -->
		<h1 class="text-3xl sm:text-4xl font-bold text-slate-900 leading-tight mb-8">{title}</h1>

		<hr class="border-slate-100 mb-8" />

		<!-- Тело статьи -->
		<div class="prose">
			<slot />
		</div>

		<!-- Нижняя навигация -->
		<div class="mt-14 pt-8 border-t border-slate-100 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
			<a href="/blog"
				class="inline-flex items-center gap-2 text-slate-500 hover:text-blue-600 text-sm font-medium transition-colors no-underline">
				<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
					<path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
				</svg>
				{t.allPosts}
			</a>
			<a href="tel:+37253383036"
				class="inline-flex items-center gap-2 bg-blue-600 hover:bg-blue-700 text-white font-semibold px-5 py-2.5 rounded-xl text-sm transition-colors no-underline">
				<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
					<path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
				</svg>
				{t.bookBtn}
			</a>
		</div>

	</article>
</main>
<Footer />
</body>
</html>
