---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const langLabels: Record<string, string> = {
	ru: '🇷🇺 Русский',
	et: '🇪🇪 Eesti',
	fi: '🇫🇮 Suomi',
};
---

<!doctype html>
<html lang="ru">
	<head>
		<BaseHead title="Блог — Sonin Hambaravi" description="Статьи о стоматологии от доктора Дмитрия Сонина на русском, эстонском и финском языках." />
		<style>
			main {
				width: 960px;
			}
			.filters {
				display: flex;
				gap: 0.5rem;
				margin-bottom: 2rem;
				flex-wrap: wrap;
			}
			.filter-btn {
				padding: 0.4em 1em;
				border: 2px solid rgb(var(--accent));
				border-radius: 2em;
				background: transparent;
				color: rgb(var(--accent));
				cursor: pointer;
				font-size: 0.9em;
				font-weight: 600;
				transition: 0.15s ease;
			}
			.filter-btn:hover,
			.filter-btn.active {
				background: rgb(var(--accent));
				color: #fff;
			}
			ul {
				display: flex;
				flex-wrap: wrap;
				gap: 2rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li {
				width: calc(50% - 1rem);
			}
			ul li * {
				text-decoration: none;
				transition: 0.2s ease;
			}
			ul li:first-child {
				width: 100%;
				margin-bottom: 1rem;
				text-align: center;
			}
			ul li:first-child .title {
				font-size: 2.369rem;
			}
			ul li img {
				margin-bottom: 0.5rem;
				border-radius: 12px;
			}
			ul li a {
				display: block;
			}
			.title {
				margin: 0;
				color: rgb(var(--black));
				line-height: 1.2;
			}
			.date {
				margin: 0.25em 0 0;
				color: rgb(var(--gray));
				font-size: 0.9em;
			}
			.lang-badge {
				display: inline-block;
				background: rgb(var(--accent));
				color: #fff;
				font-size: 0.65em;
				font-weight: 700;
				padding: 0.15em 0.5em;
				border-radius: 4px;
				letter-spacing: 0.05em;
				margin-bottom: 0.4em;
				vertical-align: middle;
			}
			ul li a:hover h4,
			ul li a:hover .date {
				color: rgb(var(--accent));
			}
			ul li[hidden] {
				display: none;
			}
			@media (max-width: 720px) {
				ul li,
				ul li:first-child {
					width: 100%;
					text-align: center;
					margin-bottom: 0;
				}
				ul li:first-child .title {
					font-size: 1.563em;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section>
				<div class="filters">
					<button class="filter-btn active" data-lang="all">Все / Kõik / Kaikki</button>
					{Object.entries(langLabels).map(([code, label]) => (
						<button class="filter-btn" data-lang={code}>{label}</button>
					))}
				</div>
				<ul id="posts-list">
					{
						posts.map((post) => (
							<li data-lang={post.data.lang}>
								<a href={`/blog/${post.id.replace(/\.(mdx?)$/, '')}/`}>
									{post.data.heroImage && (
										<img width={720} height={360} src={post.data.heroImage} alt="" />
									)}
									<span class="lang-badge">{(post.data.lang ?? 'ru').toUpperCase()}</span>
									<h4 class="title">{post.data.title}</h4>
									<p class="date">
										<FormattedDate date={post.data.pubDate} />
										{post.data.author && ` — ${post.data.author}`}
									</p>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />

		<script>
			const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
			const items = document.querySelectorAll<HTMLLIElement>('#posts-list li');

			buttons.forEach((btn) => {
				btn.addEventListener('click', () => {
					const lang = btn.dataset.lang;
					buttons.forEach((b) => b.classList.remove('active'));
					btn.classList.add('active');
					items.forEach((item) => {
						const show = lang === 'all' || item.dataset.lang === lang;
						item.hidden = !show;
					});
				});
			});
		</script>
	</body>
</html>
