---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post) => ({
		params: { slug: post.id.replace(/\.(mdx?)$/, '') },
		props: { post, allPosts: posts },
	}));
}

interface Props {
	post: CollectionEntry<'blog'>;
	allPosts: CollectionEntry<'blog'>[];
}

const { post, allPosts } = Astro.props;
const { Content } = await render(post);

// Find same-date posts in other languages for hreflang
const postDate = new Date(post.data.pubDate).toISOString().slice(0, 10);
const langVersions = allPosts
	.filter(p => {
		const d = new Date(p.data.pubDate).toISOString().slice(0, 10);
		return d === postDate && p.data.lang !== post.data.lang;
	})
	.map(p => ({
		lang: p.data.lang,
		slug: p.id.replace(/\.(mdx?)$/, ''),
	}));
---

<BlogPost {...post.data} langVersions={langVersions}>
	<Content />
</BlogPost>
