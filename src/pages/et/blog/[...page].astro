---
import { getCollection } from 'astro:content';
import type { GetStaticPathsOptions } from 'astro';
import BaseHead from '../../../components/BaseHead.astro';
import Footer from '../../../components/Footer.astro';
import FormattedDate from '../../../components/FormattedDate.astro';
import Header from '../../../components/Header.astro';

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
	const allPosts = await getCollection('blog');
	const posts = allPosts
		.filter(p => (p.data.lang ?? 'ru') === 'et')
		.sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime());
	return paginate(posts, { pageSize: 12 });
}

const { page } = Astro.props;
const posts = page.data;

const pageItems: (number | null)[] = [];
for (let n = 1; n <= page.lastPage; n++) {
	if (Math.abs(n - page.currentPage) <= 1 || n === 1 || n === page.lastPage) {
		pageItems.push(n);
	} else if (pageItems[pageItems.length - 1] !== null) {
		pageItems.push(null);
	}
}
---

<!doctype html>
<html lang="et">
<head>
	<BaseHead
		title={page.currentPage === 1 ? 'Blogi — Sonin Hambaravi' : `Blogi — lehekülg ${page.currentPage} — Sonin Hambaravi`}
		description="Artiklid hambaarstiteadusest doktor Dmitri Soninilt: implantatsioon, proteesimine, hügieen."
	/>
</head>
<body class="bg-white text-slate-800 antialiased">
<Header />
<main>

	<section class="bg-gradient-to-br from-slate-900 via-blue-950 to-slate-900 text-white py-16 px-4 sm:px-6">
		<div class="max-w-6xl mx-auto text-center">
			<span class="inline-flex items-center gap-2 bg-blue-900/60 border border-blue-700/50 text-blue-300 text-xs font-semibold uppercase tracking-widest px-4 py-1.5 rounded-full mb-6">
				<span class="w-1.5 h-1.5 bg-blue-400 rounded-full"></span>
				Kasulikud materjalid
			</span>
			<h1 class="text-4xl sm:text-5xl font-bold mb-4">Kliiniku blogi</h1>
			<p class="text-slate-300 text-lg max-w-xl mx-auto">
				Nõuanded hambahoolduse, implantatsioon ja proteesimise kohta doktor Dmitri Soninilt.
			</p>
		</div>
	</section>

	<section class="py-16 px-4 sm:px-6">
		<div class="max-w-6xl mx-auto">

			<ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8 list-none p-0 m-0">
				{posts.map((post) => (
					<li class="flex flex-col">
						<a href={`/blog/${post.id.replace(/\.(mdx?)$/, '')}/`}
							class="group flex flex-col h-full bg-white rounded-2xl border border-slate-100 shadow-sm hover:shadow-md hover:-translate-y-1 transition-all duration-200 overflow-hidden no-underline">

							{post.data.heroImage
								? <img src={post.data.heroImage} alt={post.data.title} width={720} height={360} class="w-full h-44 object-cover" loading="lazy" />
								: <div class="w-full h-44 bg-gradient-to-br from-blue-50 to-slate-100 flex items-center justify-center">
										<svg class="w-10 h-10 text-blue-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.2">
											<path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
										</svg>
									</div>
							}

							<div class="p-6 flex flex-col flex-1">
								<div class="mb-3">
									<span class="text-slate-400 text-xs"><FormattedDate date={post.data.pubDate} /></span>
								</div>
								<h2 class="text-base font-bold text-slate-900 group-hover:text-blue-600 transition-colors leading-snug mb-2 flex-1">
									{post.data.title}
								</h2>
								{post.data.description && (
									<p class="text-slate-500 text-sm leading-relaxed line-clamp-2 mb-4">{post.data.description}</p>
								)}
								<div class="flex items-center justify-between mt-auto pt-4 border-t border-slate-100">
									<span class="text-xs text-slate-400">{post.data.author}</span>
									<span class="text-blue-600 text-xs font-semibold flex items-center gap-1">
										Loe
										<svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
											<path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
										</svg>
									</span>
								</div>
							</div>
						</a>
					</li>
				))}
			</ul>

			{page.lastPage > 1 && (
				<nav class="mt-14 flex items-center justify-center gap-2" aria-label="Blogi leheküljed">
					{page.url.prev ? (
						<a href={page.url.prev} class="inline-flex items-center gap-2 px-4 py-2 rounded-xl border border-slate-200 text-slate-600 text-sm font-medium hover:bg-slate-50 transition-colors no-underline">
							<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
							Eelmine
						</a>
					) : (
						<span class="inline-flex items-center gap-2 px-4 py-2 rounded-xl border border-slate-100 text-slate-300 text-sm font-medium cursor-not-allowed">
							<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
							Eelmine
						</span>
					)}

					<div class="flex items-center gap-1">
						{pageItems.map(n =>
							n === null
								? <span class="px-1 text-slate-400 text-sm">…</span>
								: n === page.currentPage
									? <span class="w-9 h-9 flex items-center justify-center rounded-xl bg-blue-600 text-white text-sm font-semibold">{n}</span>
									: <a href={n === 1 ? '/et/blog/' : `/et/blog/${n}/`} class="w-9 h-9 flex items-center justify-center rounded-xl border border-slate-200 text-slate-600 text-sm hover:bg-slate-50 transition-colors no-underline">{n}</a>
						)}
					</div>

					{page.url.next ? (
						<a href={page.url.next} class="inline-flex items-center gap-2 px-4 py-2 rounded-xl border border-slate-200 text-slate-600 text-sm font-medium hover:bg-slate-50 transition-colors no-underline">
							Järgmine
							<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
						</a>
					) : (
						<span class="inline-flex items-center gap-2 px-4 py-2 rounded-xl border border-slate-100 text-slate-300 text-sm font-medium cursor-not-allowed">
							Järgmine
							<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
						</span>
					)}
				</nav>
			)}

		</div>
	</section>

</main>
<Footer />
</body>
</html>
