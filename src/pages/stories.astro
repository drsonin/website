---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { CLINIC_PHONE } from '../consts';

const stories = [
  {
    name: 'Андрей',
    location: 'Швеция',
    flag: '🇸🇪',
    tags: ['abroad'],
    quote: '«В Швеции за ту же работу попросили бы втрое дороже»',
    text: 'Долго сравнивал варианты — где сделать имплантацию за разумные деньги. В Швеции, где я живу, цены на стоматологию просто неподъёмные. Нашёл клинику Сонина, написал — и быстро всё организовал. Приехал, всё прошло отлично.',
    service: 'Имплантация',
  },
  {
    name: 'Галина',
    location: 'Швеция',
    flag: '🇸🇪',
    tags: ['abroad', 'referral'],
    quote: '«В Турцию не хотела. Зять посоветовал — и оказался прав»',
    text: 'Нужна была серьёзная работа, и я начала изучать варианты. Турция — не для меня, хотелось надёжнее. Зять, который сам лечится у доктора Дмитрия, сказал: "Езжай в Таллин, не пожалеешь". Послушалась. Не пожалела.',
    service: 'Имплантация',
  },
  {
    name: 'Александр',
    location: 'Финляндия',
    flag: '🇫🇮',
    tags: ['abroad'],
    quote: '«Цены понравились сразу. Приехал — и сделал»',
    text: 'Живу в Финляндии, нужно было три импланта. Стоимость лечения в Финляндии — это отдельный разговор. Нашёл клинику Сонина, цены показались разумными, и я не стал откладывать. Быстро приехал сделать снимок, а следом — на лечение.',
    service: 'Имплантация',
  },
  {
    name: 'Наталья',
    location: 'Финляндия',
    flag: '🇫🇮',
    tags: ['abroad'],
    quote: '«Решение приняла быстро — зачем откладывать?»',
    text: 'Живу в Финляндии. Когда сравнила цены здесь и там — выбор стал очевидным. Записалась, приехала. Всё прошло хорошо, без сюрпризов. Рада, что не стала тянуть.',
    service: 'Имплантация',
  },
  {
    name: 'Оксана',
    location: 'Финляндия',
    flag: '🇫🇮',
    tags: ['abroad'],
    quote: '«Важно было чувствовать себя своей. Здесь — своя»',
    text: 'Я украинка, живу в Финляндии. Нужны были импланты и новый мост. Хотелось, чтобы врач понимал меня — и по-человечески, и языково. Эстония оказалась идеальным вариантом: и ближе, и цены хорошие, и общение своё.',
    service: 'Имплантация + мост',
  },
  {
    name: 'Светлана',
    location: 'Финляндия',
    flag: '🇫🇮',
    tags: ['abroad', 'installment'],
    quote: '«Рассрочка решила всё. И цена ниже, чем дома»',
    text: 'Живу в Финляндии, но лечиться решила здесь — именно потому что есть рассрочка. Это удобно: и цена ниже финской, и платишь постепенно. Клиника произвела хорошее впечатление, доктор внимательный.',
    service: 'Имплантация',
  },
  {
    name: 'Татьяна',
    location: 'Эстония',
    flag: '🇪🇪',
    tags: ['installment'],
    quote: '«Позвонила — и в тот же день записалась»',
    text: 'Снимки у меня уже были — знала, что нужно делать. Оставалось только решиться. Когда узнала про рассрочку, сомнения исчезли: не нужно ждать, пока соберёшь всю сумму. Позвонила в клинику и записалась на консультацию в тот же день.',
    service: 'Имплантация',
  },
  {
    name: 'Марианна',
    location: 'Эстония',
    flag: '🇪🇪',
    tags: ['installment', 'full-jaw'],
    quote: '«Думала, что такое лечение мне просто недоступно»',
    text: 'Нужно было делать всю челюсть — это большие деньги. Думала, что придётся ещё долго копить. Но здесь предложили рассрочку на три года — и всё изменилось. Наконец решилась начать. Теперь лечусь и не переживаю о том, где взять всю сумму сразу.',
    service: 'Полное восстановление',
  },
  {
    name: 'Лариса',
    location: 'Эстония',
    flag: '🇪🇪',
    tags: ['installment'],
    quote: '«Четыре импланта — решение приняла быстро»',
    text: 'Нужно было сделать четыре импланта. Сумма немаленькая. Но как только узнала про рассрочку — долго думать не стала. Пришла на консультацию, всё объяснили, вопросов не осталось. Начала лечение.',
    service: 'Имплантация',
  },
  {
    name: 'Яна',
    location: 'Эстония',
    flag: '🇪🇪',
    tags: ['elsewhere', 'installment', 'full-jaw'],
    quote: '«Думала про Турцию. Посчитала всё — и осталась в Таллине»',
    text: 'Нужна была серьёзная работа — вся челюсть. Рассматривала Турцию и Беларусь: казалось, там дешевле. Но когда посчитала дорогу, проживание, возможные проблемы с гарантией — разница стала куда меньше. А здесь — Европа, рассрочка, и можно приехать на контроль когда нужно.',
    service: 'Полное восстановление',
  },
  {
    name: 'Ирина',
    location: 'Эстония',
    flag: '🇪🇪',
    tags: ['elsewhere', 'full-jaw'],
    quote: '«Уже почти ехала в Беларусь. Хорошо, что не уехала»',
    text: 'Договорилась лечить всю челюсть в Беларуси — казалось, там выгоднее. Но в последний момент узнала о клинике Сонина. Сравнила всё — и осталась в Таллине. Ближе, удобнее, европейское качество. Рада, что изменила решение.',
    service: 'Полное восстановление',
  },
  {
    name: 'Инна',
    location: 'Эстония',
    flag: '🇪🇪',
    tags: ['referral'],
    quote: '«Знакомый посоветовал — и я не пожалела»',
    text: 'Узнала о клинике от знакомого, который здесь лечился. Когда кто-то из близких говорит "иди туда" — это совсем другое доверие, чем просто отзыв в интернете. Поставила два импланта. Всё прошло хорошо, доктор подробно объяснил каждый шаг.',
    service: 'Имплантация',
  },
  {
    name: 'Ирина С.',
    location: 'Эстония',
    flag: '🇪🇪',
    tags: ['referral', 'installment'],
    quote: '«Подруга рассказала — и сомнений не осталось»',
    text: 'Долго откладывала лечение, сравнивала варианты. Потом подруга, которая уже лечилась у доктора Дмитрия, рассказала о своём опыте — и это стало решающим. Ещё и рассрочка помогла: не надо было ждать, пока соберёшь всю сумму.',
    service: 'Имплантация',
  },
  {
    name: 'Лира',
    location: 'Эстония',
    flag: '🇪🇪',
    tags: ['referral'],
    quote: '«Коронки на все зубы — пришла, потому что доверяла»',
    text: 'Нужны были коронки на все зубы — работа непростая. Пришла по рекомендации знакомых, которые уже лечились здесь. Уровень доверия был высокий с самого начала. Так и оказалось — всё сделано качественно.',
    service: 'Протезирование',
  },
  {
    name: 'Людмила',
    location: 'Эстония',
    flag: '🇪🇪',
    tags: ['redo'],
    quote: '«В другой клинике не прижились. Дмитрий — разобрался»',
    text: 'В другой клинике поставили импланты — они не прижились. Не знала, что делать. Обратилась к доктору Дмитрию: он внимательно разобрался в ситуации, переделал работу. Сейчас всё хорошо — никаких проблем. Жаль, что не обратилась сюда сразу.',
    service: 'Переделка имплантации',
  },
  {
    name: 'Марина',
    location: 'Эстония',
    flag: '🇪🇪',
    tags: ['trust'],
    quote: '«Вопросов не было — доктор сразу внушил доверие»',
    text: 'Нужны были импланты и коронки на жевательные зубы. Пришла на консультацию — доктор Дмитрий сразу произвёл впечатление: внимательный, объясняет понятно. Вопросов практически не было. Лечение прошло спокойно.',
    service: 'Имплантация + коронки',
  },
  {
    name: 'Татьяна К.',
    location: 'Эстония',
    flag: '🇪🇪',
    tags: ['trust'],
    quote: '«На консультации всё стало ясно. Я даже не думала идти куда-то ещё»',
    text: 'Доктор Дмитрий объяснил мне всё — что нужно делать, в каком порядке, почему. По-человечески, без лишних слов. Я поняла, что мне нужно, и сразу приняла решение. Даже не рассматривала другие клиники.',
    service: 'Имплантация + коронки',
  },
  {
    name: 'Александр К.',
    location: 'Эстония',
    flag: '🇪🇪',
    tags: ['trust'],
    quote: '«Быстро принял решение. С тех пор всех отправляю сюда»',
    text: 'Пришёл на консультацию — и быстро понял, что хочу лечиться здесь. Не было ощущения, что на тебя давят или пытаются "продать" лишнее. Доктор сказал то, что нужно — и только то. Лечение прошло хорошо. Теперь рекомендую клинику всем знакомым.',
    service: 'Имплантация',
  },
];

const filters = [
  { id: 'all',         label: 'Все истории' },
  { id: 'abroad',      label: 'Приехал из-за рубежа' },
  { id: 'installment', label: 'Лечение в рассрочку' },
  { id: 'full-jaw',    label: 'Полное восстановление' },
  { id: 'referral',    label: 'По рекомендации' },
  { id: 'elsewhere',   label: 'Рассматривал Турцию / Беларусь' },
  { id: 'redo',        label: 'Переделали чужую работу' },
  { id: 'trust',       label: 'Доверие к доктору' },
];

const tagLabels: Record<string, string> = {
  abroad:      'Из-за рубежа',
  installment: 'Рассрочка',
  'full-jaw':  'Вся челюсть',
  referral:    'По рекомендации',
  elsewhere:   'Сравнивал варианты',
  redo:        'Переделали',
  trust:       'Доверие к врачу',
};
---

<!doctype html>
<html lang="ru">
<head>
  <BaseHead
    title="Истории пациентов — Sonin Hambaravi"
    description="Реальные истории пациентов клиники Sonin Hambaravi. Из Финляндии, Швеции, Эстонии — с разными ситуациями и разными путями к нам. Узнайте себя."
  />
</head>
<body class="bg-white text-slate-800 antialiased">
<Header />
<main>

  <!-- ═══ HERO ══════════════════════════════════════════════ -->
  <section class="bg-gradient-to-br from-slate-900 via-blue-950 to-slate-900 text-white py-16 px-4 sm:px-6">
    <div class="max-w-6xl mx-auto text-center">
      <span class="inline-flex items-center gap-2 bg-blue-900/60 border border-blue-700/50 text-blue-300 text-xs font-semibold uppercase tracking-widest px-4 py-1.5 rounded-full mb-6">
        <span class="w-1.5 h-1.5 bg-blue-400 rounded-full"></span>
        Реальные люди, реальные ситуации
      </span>
      <h1 class="text-4xl sm:text-5xl font-bold mb-4">Истории наших пациентов</h1>
      <p class="text-slate-300 text-lg max-w-2xl mx-auto">
        Каждый пришёл со своей ситуацией. Найдите себя — и поймите, что решение возможно.
      </p>
    </div>
  </section>

  <!-- ═══ FILTERS ════════════════════════════════════════════ -->
  <section class="bg-white border-b border-slate-200 py-4 px-4 sm:px-6 sticky top-16 z-40 shadow-sm">
    <div class="max-w-6xl mx-auto">
      <div class="flex gap-2 overflow-x-auto" id="filter-bar" style="scrollbar-width: none; -ms-overflow-style: none;">
        {filters.map(f => (
          <button
            data-filter={f.id}
            class:list={[
              'filter-btn flex-shrink-0 whitespace-nowrap px-4 py-2 rounded-full text-sm font-medium border transition-all duration-150 cursor-pointer',
              f.id === 'all'
                ? 'bg-blue-600 text-white border-blue-600'
                : 'bg-white text-slate-600 border-slate-200 hover:border-blue-400 hover:text-blue-600',
            ]}
          >
            {f.label}
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ STORIES GRID ══════════════════════════════════════ -->
  <section class="py-12 px-4 sm:px-6">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6" id="stories-grid">
        {stories.map(s => (
          <article
            data-tags={s.tags.join(' ')}
            class="story-card bg-white rounded-2xl border border-slate-200 shadow-sm hover:shadow-md transition-shadow duration-200 flex flex-col overflow-hidden"
          >
            <!-- Card header -->
            <div class="bg-slate-50 px-5 pt-5 pb-4 flex items-start gap-3">
              <!-- Avatar -->
              <div class="w-11 h-11 rounded-full bg-blue-600 flex items-center justify-center text-white font-bold text-base flex-shrink-0">
                {s.name[0]}
              </div>
              <div class="min-w-0">
                <p class="font-semibold text-slate-900 text-sm leading-tight">{s.name}</p>
                <p class="text-slate-500 text-xs mt-0.5">{s.flag} {s.location} · {s.service}</p>
              </div>
            </div>

            <!-- Quote -->
            <div class="px-5 pt-4">
              <p class="text-blue-700 font-semibold text-sm leading-snug">{s.quote}</p>
            </div>

            <!-- Story text -->
            <div class="px-5 pt-3 pb-5 flex-1">
              <p class="text-slate-600 text-sm leading-relaxed">{s.text}</p>
            </div>

            <!-- Tags -->
            <div class="px-5 pb-5 flex flex-wrap gap-1.5">
              {s.tags.map(tag => (
                <span class="inline-block bg-blue-50 text-blue-600 text-xs font-medium px-2.5 py-1 rounded-full border border-blue-100">
                  {tagLabels[tag] ?? tag}
                </span>
              ))}
            </div>
          </article>
        ))}
      </div>

      <!-- Empty state -->
      <div id="empty-state" class="hidden text-center py-16 text-slate-400">
        <p class="text-lg">По этому фильтру историй пока нет</p>
      </div>
    </div>
  </section>

  <!-- ═══ CTA ═══════════════════════════════════════════════ -->
  <section class="bg-gradient-to-br from-blue-600 to-blue-700 text-white py-16 px-4 sm:px-6">
    <div class="max-w-2xl mx-auto text-center">
      <h2 class="text-3xl sm:text-4xl font-bold mb-4">Узнали себя?</h2>
      <p class="text-blue-100 text-lg mb-8">
        Запишитесь на консультацию — расскажите свою ситуацию, и мы найдём решение вместе.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/#contact"
          class="bg-white text-blue-700 hover:bg-blue-50 font-bold px-8 py-4 rounded-xl text-lg transition-colors duration-150 no-underline"
        >
          Написать нам
        </a>
        <a
          href={`tel:${CLINIC_PHONE}`}
          class="bg-blue-500 hover:bg-blue-400 border border-blue-400 text-white font-semibold px-8 py-4 rounded-xl text-lg transition-colors duration-150 no-underline"
        >
          Позвонить: {CLINIC_PHONE}
        </a>
      </div>
    </div>
  </section>

</main>
<Footer />
</body>
</html>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const cards = document.querySelectorAll<HTMLElement>('.story-card');
  const emptyState = document.getElementById('empty-state')!;

  function setFilter(active: string) {
    // Update button styles
    buttons.forEach(btn => {
      const isActive = btn.dataset.filter === active;
      btn.classList.toggle('bg-blue-600', isActive);
      btn.classList.toggle('text-white', isActive);
      btn.classList.toggle('border-blue-600', isActive);
      btn.classList.toggle('bg-white', !isActive);
      btn.classList.toggle('text-slate-600', !isActive);
      btn.classList.toggle('border-slate-200', !isActive);
    });

    // Show/hide cards
    let visible = 0;
    cards.forEach(card => {
      const tags = (card.dataset.tags ?? '').split(' ');
      const show = active === 'all' || tags.includes(active);
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });

    emptyState.classList.toggle('hidden', visible > 0);
  }

  buttons.forEach(btn => {
    btn.addEventListener('click', () => setFilter(btn.dataset.filter ?? 'all'));
  });
</script>
