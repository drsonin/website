---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CookieBanner from '../components/CookieBanner.astro';
import { getLangFromUrl } from '../i18n/translations';
import { CLINIC_PHONE } from '../consts';

const lang = getLangFromUrl(Astro.url);

const t = {
  ru: {
    title: 'Страница не найдена — Sonin Hambaravi',
    code: '404',
    heading: 'Страница не найдена',
    text: 'Возможно, ссылка устарела или была допущена опечатка в адресе.',
    home: 'На главную',
    contact: 'Записаться на приём',
    phone: 'Позвонить',
  },
  et: {
    title: 'Lehte ei leitud — Sonin Hambaravi',
    code: '404',
    heading: 'Lehte ei leitud',
    text: 'Võimalik, et link on aegunud või aadressis on kirjaviga.',
    home: 'Avaleht',
    contact: 'Registreeri visiidile',
    phone: 'Helista',
  },
  fi: {
    title: 'Sivua ei löydy — Sonin Hambaravi',
    code: '404',
    heading: 'Sivua ei löydy',
    text: 'Linkki saattaa olla vanhentunut tai osoitteessa on kirjoitusvirhe.',
    home: 'Etusivu',
    contact: 'Varaa aika',
    phone: 'Soita',
  },
  en: {
    title: 'Page not found — Sonin Hambaravi',
    code: '404',
    heading: 'Page not found',
    text: 'The link may be outdated or there may be a typo in the address.',
    home: 'Home',
    contact: 'Book an appointment',
    phone: 'Call us',
  },
}[lang];

const homeHref = lang === 'ru' ? '/' : `/${lang}/`;
const contactHref = lang === 'ru' ? '/#contact' : `/${lang}/#contact`;
---

<!doctype html>
<html lang={lang}>
<head>
  <BaseHead title={t.title} description={t.text} />
</head>
<body class="bg-white text-slate-800 antialiased">
<Header />

<main class="min-h-[70vh] flex items-center justify-center px-4 py-20">
  <div class="max-w-lg mx-auto text-center">

    <!-- Большой номер -->
    <div class="text-[120px] sm:text-[160px] font-black text-blue-100 leading-none select-none mb-2">
      404
    </div>

    <!-- Иконка зуба -->
    <div class="w-16 h-16 bg-blue-600 rounded-2xl flex items-center justify-center mx-auto mb-6 -mt-4">
      <svg class="w-9 h-9 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6">
        <path stroke-linecap="round" stroke-linejoin="round"
          d="M12 2C9 2 6.5 4 6.5 6.5c0 1.2.4 2.3.4 3.5 0 2-1 3.5-1 5.5 0 2 1 4 2.5 4s2-1.5 2.5-3.5c.3-1 .5-1.5 1.1-1.5s.8.5 1.1 1.5c.5 2 1 3.5 2.5 3.5s2.5-2 2.5-4c0-2-1-3.5-1-5.5 0-1.2.4-2.3.4-3.5C17.5 4 15 2 12 2z"/>
      </svg>
    </div>

    <h1 class="text-2xl sm:text-3xl font-bold text-slate-900 mb-3">{t.heading}</h1>
    <p class="text-slate-500 mb-10">{t.text}</p>

    <div class="flex flex-col sm:flex-row gap-3 justify-center">
      <a href={homeHref}
        class="inline-flex items-center justify-center gap-2 bg-blue-600 hover:bg-blue-700 text-white font-bold px-6 py-3 rounded-xl text-sm transition-colors no-underline">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
        </svg>
        {t.home}
      </a>
      <a href={contactHref}
        class="inline-flex items-center justify-center gap-2 border-2 border-blue-200 hover:border-blue-400 text-blue-700 font-semibold px-6 py-3 rounded-xl text-sm transition-colors no-underline">
        {t.contact}
      </a>
      <a href={`tel:${CLINIC_PHONE}`}
        class="inline-flex items-center justify-center gap-2 bg-slate-50 hover:bg-slate-100 text-slate-700 font-semibold px-6 py-3 rounded-xl text-sm transition-colors no-underline border border-slate-200">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
        </svg>
        {t.phone}
      </a>
    </div>

  </div>
</main>

<Footer />
<CookieBanner />
</body>
</html>
